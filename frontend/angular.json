{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "freepeepee": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "fp",
      "architect": {
        "build": {
          "builder": "@angular-builders/custom-webpack:browser",
          "options": {
            "customWebpackConfig": { "path": "./webpack.config.js" },
            "outputPath": "dist/freepeepee",
            "index": "src/index.html",
            "main": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "polyfills": ["zone.js"],
            "inlineStyleLanguage": "scss",
            "assets": ["src/assets", "src/manifest.webmanifest", "src/favicon.svg"],
            "styles": ["src/styles.scss", "node_modules/leaflet/dist/leaflet.css"],
            "serviceWorker": true,
            "ngswConfigPath": "ngsw-config.json"
          },
          "configurations": {
            "production": {
              "budgets": [
                { "type": "initial", "maximumWarning": "1mb", "maximumError": "2mb" }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-builders/custom-webpack:dev-server",
          "configurations": {
            "production": { "buildTarget": "freepeepee:build:production" },
            "development": { "buildTarget": "freepeepee:build:development" }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular-builders/custom-webpack:karma",
          "options": {
            "customWebpackConfig": { "path": "./webpack.config.js" },
            "karmaConfig": "karma.conf.js",
            "polyfills": ["zone.js", "zone.js/testing"],
            "tsConfig": "tsconfig.spec.json",
            "inlineStyleLanguage": "scss",
            "assets": ["src/assets"],
            "styles": ["src/styles.scss"]
          }
        }
      }
    }
  }
}

.fp-list
  .fp-list__top
    mat-form-field.fp-list__search(appearance="outline", subscriptSizing="dynamic")
      mat-label search
      input(matInput, [formControl]="searchCtrl", placeholder="name, address, notes…")
      mat-icon(matSuffix) search
    .fp-list__top-actions
      button(mat-flat-button, color="primary", (click)="add()")
        mat-icon add
        | new freepeepee
      button(mat-icon-button, (click)="reload()", matTooltip="refresh")
        mat-icon refresh

  .fp-list__table-wrap
    table.fp-list__table(mat-table, [dataSource]="rows()")

      ng-container(matColumnDef="name")
        th(mat-header-cell, *matHeaderCellDef) name
        td(mat-cell, *matCellDef="let t") {{ t.name }}

      ng-container(matColumnDef="address")
        th(mat-header-cell, *matHeaderCellDef) location
        td(mat-cell, *matCellDef="let t") {{ t.address }}

      ng-container(matColumnDef="pinCode")
        th(mat-header-cell, *matHeaderCellDef) pin
        td.fp-mono(mat-cell, *matCellDef="let t") {{ t.pinCode || '—' }}

      ng-container(matColumnDef="isWorking")
        th(mat-header-cell, *matHeaderCellDef) status
        td(mat-cell, *matCellDef="let t")
          span.fp-dot(:class="t.isWorking ? 'fp-dot--ok' : 'fp-dot--bad'")
          span.fp-list__status-label {{ t.isWorking ? 'working' : 'broken' }}

      ng-container(matColumnDef="toiletType")
        th(mat-header-cell, *matHeaderCellDef) type
        td(mat-cell, *matCellDef="let t")
          mat-chip(highlighted) {{ t.toiletType }}

      ng-container(matColumnDef="notes")
        th(mat-header-cell, *matHeaderCellDef) notes
        td.fp-list__notes(mat-cell, *matCellDef="let t") {{ t.notes }}

      ng-container(matColumnDef="actions")
        th(mat-header-cell, *matHeaderCellDef)
        td.fp-list__actions-cell(mat-cell, *matCellDef="let t")
          button(mat-icon-button, (click)="edit(t)", matTooltip="edit")
            mat-icon edit
          button(mat-icon-button, color="warn", (click)="remove(t)", matTooltip="delete")
            mat-icon delete

      tr(mat-header-row, *matHeaderRowDef="cols; sticky: true")
      tr(mat-row, *matRowDef="let row; columns: cols")

    .fp-list__empty(*ngIf="rows().length === 0")
      mat-icon inbox
      div No freepeepees found. Add one.

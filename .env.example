# Copy to .env (NOT committed) before docker compose up.
# Generate strong values:
#   openssl rand -base64 32   for DB_PASSWORD
#   openssl rand -base64 48   for JWT_SECRET (must be >= 32 bytes for HS256)

VERSION=v0.1.0

DB_USER=freepeepee
DB_PASSWORD=changeme_use_openssl_rand

# Must be >= 32 bytes when base64-decoded; JJWT will reject shorter keys.
JWT_SECRET=changeme_use_openssl_rand_at_least_48_chars_long_xxxxxxxxxxxxxxxx

# Origins the API will accept CORS from (comma-separated). For prod, your domain.
CORS_ORIGINS=https://freepeepee.matvs.dev
